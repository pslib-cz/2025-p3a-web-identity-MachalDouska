@page
@model CoffeeRecordsIdentity.Pages.Admin.UsersModel
@{
    <table class="table">
        <thead>
            <tr>
                <th>Email</th>
                <th>Akce</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td>@user.Email</td>
                    <td>
                        <a asp-page="./UserCups" asp-route-userId="@user.Id" class="btn btn-primary">
                            Zobrazit šálky
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
